{
  "expo": {
    "name": "iHRMS Lite",
    "slug": "ihrmsliteapp",
    "version": "2.19.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ihrmsliteapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ivs.ihrmslite",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Camera access is required to scan QR codes for attendance verification. For example, you'll point your camera at a QR code displayed at your workplace entrance to record your arrival time.",
        "NSLocationWhenInUseUsageDescription": "Location access verifies you're physically present at work when marking attendance. For example, when you scan the office QR code, your location confirms you're at the workplace premises for accurate time tracking."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ],
      "edgeToEdgeEnabled": true,
      "package": "in.indovisionservices.ihrms"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "kotlinVersion": "2.0.21"
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a3026c69-b20e-47e7-93e3-ca33f25576b1"
      }
    }
  }
}
